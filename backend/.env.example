# Server
PORT=3001
NODE_ENV=development

# Database (MySQL) – required for the backend to work
# Without a running MySQL and these vars, you'll see "connect ECONNREFUSED 127.0.0.1:3306"
DB_HOST=127.0.0.1
DB_PORT=3306
DB_NAME=tycoon
DB_USER=root
DB_PASSWORD=your_password

# Optional: skip Redis (no cache, no Redis process needed)
SKIP_REDIS=true

# Optional: Redis (when not using SKIP_REDIS)
# REDIS_URL=redis://127.0.0.1:6379

# --- Multi-chain Tycoon contract (backend game controller) ---
# Set the wallet as backendGameController on each chain's Tycoon contract (owner calls setBackendGameController).
# At least one chain must be configured for backend contract actions (create/join/end games, etc.).

# Celo (default when frontend sends chain=Celo)
CELO_RPC_URL=https://rpc.ankr.com/celo
# CELO_CHAIN_ID=42220 (mainnet) or 44787 (Alfajores). Default 42220.
TYCOON_CELO_CONTRACT_ADDRESS=
BACKEND_GAME_CONTROLLER_PRIVATE_KEY=

# Polygon (optional; for Polygon frontend)
# POLYGON_RPC_URL=
# POLYGON_CHAIN_ID=137 (mainnet) or 80001 (Mumbai). Default 137.
# TYCOON_POLYGON_CONTRACT_ADDRESS=
# BACKEND_GAME_CONTROLLER_POLYGON_PRIVATE_KEY=

# Base (optional; for Base frontend)
# BASE_RPC_URL=
# BASE_CHAIN_ID=8453 (mainnet) or 84531 (goerli). Default 8453.
# TYCOON_BASE_CONTRACT_ADDRESS=
# BACKEND_GAME_CONTROLLER_BASE_PRIVATE_KEY=

# Guest registration chain (used when no chain in request). Default CELO.
# GUEST_CHAIN=CELO
