# Server
PORT=3001
NODE_ENV=development

# Database (MySQL) – required for the backend to work
# Without a running MySQL and these vars, you'll see "connect ECONNREFUSED 127.0.0.1:3306"
DB_HOST=127.0.0.1
DB_PORT=3306
DB_NAME=tycoon
DB_USER=root
DB_PASSWORD=your_password

# --- Privy (Sign in with Privy) ---
# Required for "Sign in with Privy". Get from https://dashboard.privy.io/ → your app.
# PRIVY_APP_ID must match the frontend's NEXT_PUBLIC_PRIVY_APP_ID (same Privy app).
# Without these, POST /auth/privy-signin returns 503 "Privy not configured".
# PRIVY_APP_ID=clxxxxxxxxxx
# PRIVY_APP_SECRET=your-app-secret
# Optional: JWT verification key from Dashboard → Configuration → App settings. Avoids API call per verify; can fix "invalid or expired" if verification was failing.
# PRIVY_JWT_VERIFICATION_KEY="-----BEGIN PUBLIC KEY-----\n...\n-----END PUBLIC KEY-----"

# Optional: skip Redis (no cache, no Redis process needed)
SKIP_REDIS=true

# Optional: Redis (when not using SKIP_REDIS)
# REDIS_URL=redis://127.0.0.1:6379

# --- Multi-chain Tycoon contract (backend game controller) ---
# Set the wallet as backendGameController on each chain's Tycoon contract (owner calls setBackendGameController).
# At least one chain must be configured for backend contract actions (create/join/end games, etc.).

# Celo (default when frontend sends chain=Celo)
CELO_RPC_URL=https://rpc.ankr.com/celo
# CELO_CHAIN_ID=42220 (mainnet) or 44787 (Alfajores). Default 42220.
TYCOON_CELO_CONTRACT_ADDRESS=
BACKEND_GAME_CONTROLLER_PRIVATE_KEY=

# Polygon (optional; for Polygon frontend)
# POLYGON_RPC_URL=
# POLYGON_CHAIN_ID=137 (mainnet) or 80001 (Mumbai). Default 137.
# TYCOON_POLYGON_CONTRACT_ADDRESS=
# BACKEND_GAME_CONTROLLER_POLYGON_PRIVATE_KEY=

# Base (optional; for Base frontend)
# BASE_RPC_URL=
# BASE_CHAIN_ID=8453 (mainnet) or 84531 (goerli). Default 8453.
# TYCOON_BASE_CONTRACT_ADDRESS=
# BACKEND_GAME_CONTROLLER_BASE_PRIVATE_KEY=

# Guest registration chain (used when no chain in request). Default CELO.
# GUEST_CHAIN=CELO

# --- Internal AI agent (human vs AI games) ---
# When a human starts an AI game, the backend uses this agent to decide moves (buy, trade, build)
# instead of rule-based logic. One logical agent per game; no separate process.
# ANTHROPIC_API_KEY=sk-ant-...
# Optional: set to "false" to disable internal agent and use built-in rules only.
# USE_INTERNAL_AI_AGENT=true
# Optional: model and timeout (default: claude-sonnet-4-20250514, 15000 ms).
# INTERNAL_AGENT_MODEL=claude-sonnet-4-20250514
# INTERNAL_AGENT_TIMEOUT_MS=15000

# --- ERC-8004 Agent Identity & Reputation (Celo) ---
# One-time: run backend/scripts/register-erc8004-agent.js to register your AI and get an agentId.
# AGENT_URI=https://base-monopoly.vercel.app/tycoon-ai.json
# ERC8004_REGISTRANT_PRIVATE_KEY=0x...   # optional: script falls back to BACKEND_GAME_CONTROLLER_PRIVATE_KEY
# After registration, set ERC8004_AGENT_ID so the backend submits reputation feedback after each AI game (user signs only once for claim).
# ERC8004_AGENT_ID=12345
# Optional: use a different wallet for submitting feedback (contract disallows "self feedback" - agent owner cannot submit for their own agent).
# Set this to a wallet that is NOT the one that registered the agent; wallet needs a little CELO for gas.
# ERC8004_FEEDBACK_PRIVATE_KEY=0x...
# Optional: Celo Reputation Registry address (default: 0x8004BAa17C55a88189AE136b182e5fdA19dE9b63)
# ERC8004_REPUTATION_REGISTRY_ADDRESS=0x...

# --- NGN payments (Flutterwave) — for perk bundle purchases in Naira ---
# From Flutterwave Dashboard → Settings → API Keys. Use test keys for development.
# FLW_SECRET_KEY=FLWSECK_TEST-... or FLWSECK-... (live)
# Optional: set in Dashboard → Settings → Webhooks and verify in webhook handler (recommended).
# FLW_SECRET_HASH=your_webhook_secret_hash
# Optional: full URL to logo shown on Flutterwave checkout (e.g. https://yoursite.com/logo.png). If unset, uses FRONTEND_URL + /game/rewardrealm.svg when FRONTEND_URL is set.
# FLW_LOGO_URL=https://yoursite.com/logo.png
